# Never commit a real key. The deterministic replay path must work without one.
OPENAI_API_KEY=
GRAPHREFLY_STACK_MODEL=gpt-5.6-sol
GRAPHREFLY_STACK_REASONING_EFFORT=high
GRAPHREFLY_STACK_BLUEPRINT_PROVIDER=graphrefly

# Local development server; the app scaffold will decide the final convention.
PORT=3000
