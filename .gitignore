# Dependencies and package-manager state
node_modules/
.pnpm-store/

# Build and test output
dist/
build/
coverage/
*.tsbuildinfo
*.log

# Local environment
.env
.env.*
!.env.example

# Private Build Week material and unredacted model output
.private/

# Evidence runs commit only reviewed portable bundles and compact summaries.
# Expanded artifact trees are reproducible runtime output.
evidence/runs/**/*
!evidence/runs/**/
!evidence/runs/**/README.md
!evidence/runs/**/evidence-bundle.json
!evidence/runs/**/summary.json

# Large demo captures belong on the submission host, not in Git
evidence/media/*.mp4
evidence/media/*.mov
evidence/demo/.waveform-cache/

# Editors and operating systems
.DS_Store
.idea/
.vscode/
*.swp
*.swo
