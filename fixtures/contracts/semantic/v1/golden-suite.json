							"toNodeId": "broker"
						},
						"rationale": "All session mutation must flow through the broker."
					}
				],
				"requiredChecks": ["typecheck", "test"]
			},
			{
				"id": "HTTP",
				"title": "Expose the adapter",
				"intent": "Expose the verified runtime through the HTTP adapter.",
