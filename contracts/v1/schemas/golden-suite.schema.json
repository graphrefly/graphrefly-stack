{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "urn:graphrefly-stack:schema:golden-suite:v1",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"schema",
		"task",
		"stack",
		"provider",
		"manifest",
		"changePlan",
		"snapshots",
		"deltas",
		"semanticChanges",
		"checks",
		"cases"
	],
	"properties": {
		"schema": { "const": "urn:graphrefly-stack:schema:golden-suite:v1" },
		"task": { "$ref": "urn:graphrefly-stack:schema:artifacts:v1#/definitions/Task" },
		"stack": { "$ref": "urn:graphrefly-stack:schema:artifacts:v1#/definitions/GitStack" },
		"provider": {
			"$ref": "urn:graphrefly-stack:schema:artifacts:v1#/definitions/BlueprintProviderCapabilities"
		},
		"manifest": { "$ref": "urn:graphrefly-stack:schema:artifacts:v1#/definitions/BundleManifest" },
		"changePlan": { "$ref": "urn:graphrefly-stack:schema:artifacts:v1#/definitions/ChangePlan" },
		"snapshots": {
			"type": "array",
			"minItems": 2,
			"items": { "$ref": "urn:graphrefly-stack:schema:artifacts:v1#/definitions/BlueprintSnapshot" }
		},
		"deltas": {
			"type": "array",
			"minItems": 1,
			"items": { "$ref": "urn:graphrefly-stack:schema:artifacts:v1#/definitions/BlueprintDelta" }
		},
		"semanticChanges": {
			"type": "array",
			"minItems": 3,
			"items": {
				"$ref": "urn:graphrefly-stack:schema:artifacts:v1#/definitions/SemanticChangeRecord"
			}
		},
		"checks": {
			"type": "array",
			"items": { "$ref": "urn:graphrefly-stack:schema:artifacts:v1#/definitions/CheckResult" }
		},
		"cases": {
			"type": "array",
			"minItems": 6,
			"maxItems": 6,
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": [
					"caseId",
					"baseSnapshotIndex",
					"currentSnapshotIndex",
					"deltaIndex",
					"expectedGate",
					"selectiveReplan",
					"reviewDecision"
				],
				"properties": {
					"caseId": {
						"enum": [
							"current-valid",
							"clean-rebase-semantic-stale",
							"unrelated-change-still-valid",
							"stale-parent",
							"forged-or-wrong-scope",
							"fresh-selective-replan"
						]
					},
					"baseSnapshotIndex": { "type": "integer", "minimum": 0 },
					"currentSnapshotIndex": { "type": "integer", "minimum": 0 },
					"deltaIndex": { "type": "integer", "minimum": 0 },
					"expectedGate": {
						"$ref": "urn:graphrefly-stack:schema:artifacts:v1#/definitions/GateResult"
					},
					"selectiveReplan": {
						"anyOf": [
							{ "$ref": "urn:graphrefly-stack:schema:artifacts:v1#/definitions/SelectiveReplan" },
							{ "type": "null" }
						]
					},
					"reviewDecision": {
						"$ref": "urn:graphrefly-stack:schema:artifacts:v1#/definitions/ReviewDecision"
					}
				}
			}
		}
	}
}
