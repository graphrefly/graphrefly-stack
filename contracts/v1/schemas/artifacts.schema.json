{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "urn:graphrefly-stack:schema:artifacts:v1",
	"definitions": {
		"Hash": {
			"type": "object",
			"additionalProperties": false,
			"required": ["algorithm", "value"],
			"properties": {
				"algorithm": { "const": "sha256" },
				"value": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
			}
		},
		"GitOid": {
			"oneOf": [
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["algorithm", "value"],
					"properties": {
						"algorithm": { "const": "sha1" },
						"value": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
					}
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["algorithm", "value"],
					"properties": {
						"algorithm": { "const": "sha256" },
						"value": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
					}
				}
			]
		},
		"RepoPath": {
			"type": "string",
			"minLength": 1,
			"pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+$"
		},
		"ReasonCode": {
			"type": "string",
			"enum": [
				"SCHEMA_INVALID",
				"PROVIDER_CAPABILITY_UNSUPPORTED",
				"BLUEPRINT_DIAGNOSTICS_ERROR",
				"COMMIT_NOT_FOUND",
				"COMMIT_BINDING_MISMATCH",
				"PATCH_ID_AMBIGUOUS",
				"SOURCE_SCOPE_VIOLATION",
				"SEMANTIC_PARENT_STALE",
				"DEPENDENCY_INVALID",
				"BLUEPRINT_WITNESS_STALE",
				"POLICY_REVISION_STALE",
				"POLICY_SESSION_WRITE_REQUIRES_BROKER",
				"REQUIRED_CHECK_MISSING",
				"REQUIRED_CHECK_FAILED",
				"ARTIFACT_HASH_MISMATCH"
			]
		},
		"Node": {
			"type": "object",
			"additionalProperties": false,
			"required": ["id", "factory", "deps"],
			"properties": {
				"id": { "type": "string", "minLength": 1 },
				"name": { "type": "string", "minLength": 1 },
				"factory": { "type": "string", "minLength": 1 },
				"deps": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
				"meta": { "type": "object", "additionalProperties": true }
			}
		},
		"Edge": {
			"type": "object",
			"additionalProperties": false,
			"required": ["from", "to"],
			"properties": {
				"from": { "type": "string", "minLength": 1 },
				"to": { "type": "string", "minLength": 1 }
			}
		},
		"Topology": {
			"type": "object",
			"additionalProperties": false,
			"required": ["nodes", "edges"],
			"properties": {
				"name": { "type": "string" },
				"nodes": { "type": "array", "items": { "$ref": "#/definitions/Node" } },
				"edges": { "type": "array", "items": { "$ref": "#/definitions/Edge" } },
				"subgraphs": {
					"type": "array",
					"items": { "$ref": "#/definitions/Topology" }
				}
			}
		},
		"GraphBlueprint": {
			"type": "object",
			"additionalProperties": false,
			"required": ["version", "topology", "hash"],
			"properties": {
				"version": { "const": "graphrefly.blueprint.v1" },
				"topology": { "$ref": "#/definitions/Topology" },
				"provenance": { "type": "object", "additionalProperties": true },
				"diagnostics": {
					"type": "object",
					"additionalProperties": false,
					"required": ["ok", "issues"],
					"properties": {
						"ok": { "type": "boolean" },
						"issues": {
							"type": "array",
							"items": { "type": "object", "additionalProperties": true }
						}
					}
				},
				"hash": {
					"type": "object",
					"additionalProperties": false,
					"required": ["kind", "algorithm", "input", "value"],
					"properties": {
						"kind": { "const": "topology" },
						"algorithm": { "const": "sha256" },
						"input": { "const": "strictCanonicalTopologyBytes" },
						"value": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
					}
				}
			}
		},
		"Task": {
			"type": "object",
			"additionalProperties": false,
			"required": ["schema", "taskId", "text"],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:task:v1" },
				"taskId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9.-]*$" },
				"text": { "type": "string", "minLength": 1 }
			}
		},
		"GitStack": {
			"type": "object",
			"additionalProperties": false,
			"required": ["schema", "linearity", "base", "head", "commits"],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:git-stack:v1" },
				"linearity": { "const": "linear" },
				"base": { "$ref": "#/definitions/GitOid" },
				"head": { "$ref": "#/definitions/GitOid" },
				"commits": {
					"type": "array",
					"minItems": 1,
					"items": {
						"type": "object",
						"additionalProperties": false,
						"required": ["oid", "parent", "role", "workUnitId"],
						"properties": {
							"oid": { "$ref": "#/definitions/GitOid" },
							"parent": {
								"anyOf": [{ "$ref": "#/definitions/GitOid" }, { "type": "null" }]
							},
							"role": { "enum": ["base", "concurrent", "work-unit", "replan"] },
							"workUnitId": { "type": ["string", "null"] }
						}
					}
				}
			}
		},
		"BlueprintProviderCapabilities": {
			"type": "object",
			"additionalProperties": false,
			"required": ["schema", "providerId", "providerVersion", "blueprintVersion", "capabilities"],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:blueprint-provider-capabilities:v1" },
				"providerId": { "const": "graphrefly" },
				"providerVersion": { "type": "string", "minLength": 1 },
				"blueprintVersion": { "const": "graphrefly.blueprint.v1" },
				"capabilities": {
					"type": "object",
					"additionalProperties": false,
					"required": [
						"commitSnapshot",
						"canonicalTopologyBytes",
						"nodeMetadata",
						"subgraphs",
						"diagnostics",
						"structuralDelta",
						"mergeParentSelection",
						"claimImpact"
					],
					"properties": {
						"commitSnapshot": { "const": true },
						"canonicalTopologyBytes": { "const": true },
						"nodeMetadata": { "const": true },
						"subgraphs": { "const": true },
						"diagnostics": { "const": true },
						"structuralDelta": { "const": true },
						"mergeParentSelection": { "const": false },
						"claimImpact": { "const": false }
					}
				}
			}
		},
		"BlueprintSnapshot": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"schema",
				"commit",
				"semanticParent",
				"provider",
				"blueprint",
				"topologyHash",
				"policyRevision"
			],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:blueprint-snapshot:v1" },
				"commit": { "$ref": "#/definitions/GitOid" },
				"semanticParent": { "anyOf": [{ "$ref": "#/definitions/GitOid" }, { "type": "null" }] },
				"provider": { "$ref": "#/definitions/BlueprintProviderCapabilities" },
				"blueprint": { "$ref": "#/definitions/GraphBlueprint" },
				"topologyHash": { "$ref": "#/definitions/Hash" },
				"policyRevision": { "type": "string", "minLength": 1 }
			}
		},
		"BlueprintDelta": {
			"type": "object",
			"additionalProperties": false,
			"required": ["schema", "from", "to", "structural", "claimImpacts"],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:blueprint-delta:v1" },
				"from": { "$ref": "#/definitions/Hash" },
				"to": { "$ref": "#/definitions/Hash" },
				"structural": {
					"type": "object",
					"additionalProperties": false,
					"required": ["addedNodes", "removedNodeIds", "addedEdges", "removedEdges"],
					"properties": {
						"addedNodes": { "type": "array", "items": { "$ref": "#/definitions/Node" } },
						"removedNodeIds": {
							"type": "array",
							"items": { "type": "string" },
							"uniqueItems": true
						},
						"addedEdges": { "type": "array", "items": { "$ref": "#/definitions/Edge" } },
						"removedEdges": { "type": "array", "items": { "$ref": "#/definitions/Edge" } }
					}
				},
				"claimImpacts": {
					"type": "array",
					"items": {
						"type": "object",
						"additionalProperties": false,
						"required": ["workUnitId", "claimId", "impact"],
						"properties": {
							"workUnitId": { "type": "string" },
							"claimId": { "type": "string" },
							"impact": { "enum": ["none", "affected"] }
						}
					}
				}
			}
		},
		"WorkUnit": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"id",
				"title",
				"intent",
				"dependencies",
				"allowedSourceScopes",
				"blueprintClaims",
				"requiredChecks"
			],
			"properties": {
				"id": { "type": "string", "pattern": "^U[1-9][0-9]*$" },
				"title": { "type": "string", "minLength": 1 },
				"intent": { "type": "string", "minLength": 1 },
				"dependencies": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
				"allowedSourceScopes": {
					"type": "array",
					"items": { "$ref": "#/definitions/RepoPath" },
					"minItems": 1,
					"uniqueItems": true
				},
				"blueprintClaims": {
					"type": "array",
					"items": {
						"type": "object",
						"additionalProperties": false,
						"required": ["id", "statement"],
						"properties": {
							"id": { "type": "string", "minLength": 1 },
							"statement": { "type": "string", "minLength": 1 }
						}
					}
				},
				"requiredChecks": {
					"type": "array",
					"items": { "type": "string", "minLength": 1 },
					"minItems": 1,
					"uniqueItems": true
				}
			}
		},
		"ChangePlan": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"schema",
				"planId",
				"taskDigest",
				"baseCommit",
				"baseBlueprintHash",
				"policyRevision",
				"source",
				"workUnits"
			],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:change-plan:v1" },
				"planId": { "type": "string", "minLength": 1 },
				"taskDigest": { "$ref": "#/definitions/Hash" },
				"baseCommit": { "$ref": "#/definitions/GitOid" },
				"baseBlueprintHash": { "$ref": "#/definitions/Hash" },
				"policyRevision": { "type": "string", "minLength": 1 },
				"source": { "enum": ["fixture", "codex"] },
				"workUnits": {
					"type": "array",
					"items": { "$ref": "#/definitions/WorkUnit" },
					"minItems": 1
				}
			}
		},
		"SemanticChangeRecord": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"schema",
				"recordId",
				"workUnitId",
				"commit",
				"stablePatchId",
				"diffDigest",
				"semanticParentRecordId",
				"semanticParentCommit",
				"allowedSourceScopes",
				"sourceScopeDigest",
				"blueprintClaims",
				"dependencies",
				"requiredChecks",
				"blueprintHash",
				"policyRevision",
				"providerId",
				"providerVersion",
				"contractVersion",
				"rebindFrom"
			],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:semantic-change-record:v1" },
				"recordId": { "type": "string", "minLength": 1 },
				"workUnitId": { "type": "string", "pattern": "^U[1-9][0-9]*$" },
				"commit": { "$ref": "#/definitions/GitOid" },
				"stablePatchId": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
				"diffDigest": { "$ref": "#/definitions/Hash" },
				"semanticParentRecordId": { "type": ["string", "null"] },
				"semanticParentCommit": {
					"anyOf": [{ "$ref": "#/definitions/GitOid" }, { "type": "null" }]
				},
				"allowedSourceScopes": {
					"type": "array",
					"items": { "$ref": "#/definitions/RepoPath" },
					"minItems": 1,
					"uniqueItems": true
				},
				"sourceScopeDigest": { "$ref": "#/definitions/Hash" },
				"blueprintClaims": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
				"dependencies": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
				"requiredChecks": {
					"type": "array",
					"items": { "type": "string" },
					"minItems": 1,
					"uniqueItems": true
				},
				"blueprintHash": { "$ref": "#/definitions/Hash" },
				"policyRevision": { "type": "string" },
				"providerId": { "const": "graphrefly" },
				"providerVersion": { "type": "string" },
				"contractVersion": { "const": "v1" },
				"rebindFrom": { "type": ["string", "null"] }
			}
		},
		"CheckResult": {
			"type": "object",
			"additionalProperties": false,
			"required": ["schema", "checkId", "command", "exitCode", "stdoutDigest", "stderrDigest"],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:check-result:v1" },
				"checkId": { "type": "string", "minLength": 1 },
				"command": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
				"exitCode": { "type": "integer", "minimum": 0, "maximum": 255 },
				"stdoutDigest": { "$ref": "#/definitions/Hash" },
				"stderrDigest": { "$ref": "#/definitions/Hash" }
			}
		},
		"GateResult": {
			"type": "object",
			"additionalProperties": false,
			"required": ["schema", "gateVersion", "inputDigest", "verdict", "units", "checkIds"],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:gate-result:v1" },
				"gateVersion": { "const": "v1" },
				"inputDigest": { "$ref": "#/definitions/Hash" },
				"verdict": { "enum": ["pass", "blocked", "error"] },
				"units": {
					"type": "array",
					"items": {
						"type": "object",
						"additionalProperties": false,
						"required": ["workUnitId", "verdict", "reasonCodes", "invalidDependencies"],
						"properties": {
							"workUnitId": { "type": "string" },
							"verdict": { "enum": ["valid", "invalid"] },
							"reasonCodes": {
								"type": "array",
								"items": { "$ref": "#/definitions/ReasonCode" },
								"uniqueItems": true
							},
							"invalidDependencies": {
								"type": "array",
								"items": { "type": "string" },
								"uniqueItems": true
							}
						}
					}
				},
				"checkIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
			}
		},
		"SelectiveReplan": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"schema",
				"planId",
				"inputUnits",
				"preservedUnits",
				"replacements",
				"finalLineage"
			],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:selective-replan:v1" },
				"planId": { "type": "string" },
				"inputUnits": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
				"preservedUnits": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
				"replacements": {
					"type": "array",
					"items": {
						"type": "object",
						"additionalProperties": false,
						"required": ["workUnitId", "fromCommit", "toCommit"],
						"properties": {
							"workUnitId": { "type": "string" },
							"fromCommit": { "$ref": "#/definitions/GitOid" },
							"toCommit": { "$ref": "#/definitions/GitOid" }
						}
					}
				},
				"finalLineage": {
					"type": "array",
					"items": { "$ref": "#/definitions/GitOid" },
					"minItems": 1
				}
			}
		},
		"BundleManifest": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"schema",
				"runId",
				"recordedAt",
				"sourceCommit",
				"canonicalInputDigest",
				"schemaVersion",
				"promptVersion",
				"model",
				"provider",
				"graphreflyVersion",
				"policyRevision",
				"artifacts"
			],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:bundle-manifest:v1" },
				"runId": { "type": "string", "minLength": 1 },
				"recordedAt": {
					"type": "string",
					"pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
				},
				"sourceCommit": { "$ref": "#/definitions/GitOid" },
				"canonicalInputDigest": { "$ref": "#/definitions/Hash" },
				"schemaVersion": { "const": "v1" },
				"promptVersion": { "type": "string" },
				"model": {
					"type": "object",
					"additionalProperties": false,
					"required": ["source", "id", "reasoningEffort"],
					"properties": {
						"source": { "enum": ["fixture", "codex"] },
						"id": { "type": "string" },
						"reasoningEffort": { "type": "string" }
					}
				},
				"provider": { "$ref": "#/definitions/BlueprintProviderCapabilities" },
				"graphreflyVersion": { "type": "string" },
				"policyRevision": { "type": "string" },
				"artifacts": {
					"type": "array",
					"items": {
						"type": "object",
						"additionalProperties": false,
						"required": ["path", "hash"],
						"properties": {
							"path": {
								"allOf": [
									{ "$ref": "#/definitions/RepoPath" },
									{ "not": { "enum": ["README.md", "manifest.json"] } }
								]
							},
							"hash": { "$ref": "#/definitions/Hash" }
						}
					}
				}
			}
		},
		"RawDiff": {
			"type": "object",
			"additionalProperties": false,
			"required": ["schema", "workUnitId", "commit", "paths", "patch"],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:raw-diff:v1" },
				"workUnitId": { "type": "string", "minLength": 1 },
				"commit": { "$ref": "#/definitions/GitOid" },
				"paths": {
					"type": "array",
					"items": { "$ref": "#/definitions/RepoPath" },
					"uniqueItems": true
				},
				"patch": { "type": "string" }
			}
		},
		"PortableBundle": {
			"type": "object",
			"additionalProperties": false,
			"required": ["schema", "manifest", "artifacts"],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:portable-bundle:v1" },
				"manifest": { "$ref": "#/definitions/BundleManifest" },
				"artifacts": { "type": "object", "additionalProperties": true }
			}
		},
		"ReviewDecision": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"schema",
				"decision",
				"reviewerLabel",
				"recordIds",
				"recordedAt",
				"identityVerified"
			],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:review-decision:v1" },
				"decision": { "enum": ["approve", "defer", "reject"] },
				"reviewerLabel": { "type": "string", "minLength": 1 },
				"recordIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
				"recordedAt": {
					"type": "string",
					"pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
				},
				"identityVerified": { "const": false }
			}
		}
	}
}
