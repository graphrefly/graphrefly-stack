{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "urn:graphrefly-stack:schema:cli-result:v1",
	"title": "GraphReFly Stack CLI result v1",
	"oneOf": [
		{
			"type": "object",
			"additionalProperties": false,
			"required": ["schema", "command", "ok", "mode", "data"],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:cli-result:v1" },
				"command": { "$ref": "#/definitions/Command" },
				"ok": { "const": true },
				"mode": { "$ref": "#/definitions/Mode" },
				"data": {}
			}
		},
		{
			"type": "object",
			"additionalProperties": false,
			"required": ["schema", "command", "ok", "mode", "error"],
			"properties": {
				"schema": { "const": "urn:graphrefly-stack:schema:cli-result:v1" },
				"command": { "$ref": "#/definitions/Command" },
				"ok": { "const": false },
				"mode": { "$ref": "#/definitions/Mode" },
				"error": { "$ref": "#/definitions/Error" }
			}
		}
	],
	"definitions": {
		"Command": {
			"enum": ["fixture-create", "plan", "gate", "replan", "review", "export"]
		},
		"Mode": {
			"enum": ["deterministic", "replay", "live", "replay-fallback"]
		},
		"Error": {
			"type": "object",
			"additionalProperties": false,
			"required": ["code", "message"],
			"properties": {
				"code": { "type": "string", "minLength": 1 },
				"message": { "type": "string", "minLength": 1 },
				"details": {}
			}
		}
	}
}
