{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "urn:graphrefly-stack:schema:merge-group-artifacts:v1",
	"title": "GraphReFly Stack multi-Plan merge-group foundation artifacts v1",
	"definitions": {
		"NamedDigest": {
			"type": "object",
			"additionalProperties": false,
			"required": ["workUnitId", "digest"],
			"properties": {
				"workUnitId": {
					"$ref": "urn:graphrefly-stack:schema:semantic-artifacts:v1#/definitions/WorkUnitId"
				},
				"digest": { "$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash" }
			}
		},
		"PlanQualifiedCommit": {
			"type": "object",
			"additionalProperties": false,
			"required": ["schema", "planId", "workUnitId", "commit", "ownership"],
			"properties": {
				"schema": { "const": "graphrefly.stack.plan-qualified-commit.v1" },
				"planId": {
					"$ref": "urn:graphrefly-stack:schema:semantic-artifacts:v1#/definitions/Identifier"
				},
				"workUnitId": {
					"$ref": "urn:graphrefly-stack:schema:semantic-artifacts:v1#/definitions/WorkUnitId"
				},
				"commit": { "$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/GitOid" },
				"ownership": {
					"oneOf": [
						{
							"type": "object",
							"additionalProperties": false,
							"required": ["kind", "planTrailer", "workUnitTrailer"],
							"properties": {
								"kind": { "const": "native" },
								"planTrailer": {
									"type": "object",
									"additionalProperties": false,
									"required": ["name", "value", "occurrences"],
									"properties": {
										"name": { "const": "GraphReFly-Plan" },
										"value": {
											"$ref": "urn:graphrefly-stack:schema:semantic-artifacts:v1#/definitions/Identifier"
										},
										"occurrences": { "const": 1 }
									}
								},
								"workUnitTrailer": {
									"type": "object",
									"additionalProperties": false,
									"required": ["name", "value", "occurrences"],
									"properties": {
										"name": { "const": "GraphReFly-Work-Unit" },
										"value": {
											"$ref": "urn:graphrefly-stack:schema:semantic-artifacts:v1#/definitions/WorkUnitId"
										},
										"occurrences": { "const": 1 }
									}
								}
							}
						},
						{
							"type": "object",
							"additionalProperties": false,
							"required": ["kind", "sourceBindingDigest", "sourceGateInputDigest"],
							"properties": {
								"kind": { "const": "converted-v1" },
								"sourceBindingDigest": {
									"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
								},
								"sourceGateInputDigest": {
									"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
								}
							}
						}
					]
				}
			}
		},
		"LinearV1Conversion": {
			"type": "object",
			"additionalProperties": false,
			"required": ["schema", "converter", "source", "topologyDigest", "target"],
			"properties": {
				"schema": { "const": "graphrefly.stack.linear-v1-conversion.v1" },
				"converter": {
					"type": "object",
					"additionalProperties": false,
					"required": ["name", "version"],
					"properties": {
						"name": { "const": "graphrefly-stack" },
						"version": { "const": "v1" }
					}
				},
				"source": {
					"type": "object",
					"additionalProperties": false,
					"required": [
						"gateInputDigest",
						"gateResultDigest",
						"planDigest",
						"policyDigest",
						"bindingDigests",
						"recordDigests"
					],
					"properties": {
						"gateInputDigest": {
							"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
						},
						"gateResultDigest": {
							"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
						},
						"planDigest": {
							"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
						},
						"policyDigest": {
							"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
						},
						"bindingDigests": {
							"type": "array",
							"items": { "$ref": "#/definitions/NamedDigest" },
							"minItems": 1,
							"maxItems": 64
						},
						"recordDigests": {
							"type": "array",
							"items": { "$ref": "#/definitions/NamedDigest" },
							"minItems": 1,
							"maxItems": 64
						}
					}
				},
				"topologyDigest": {
					"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
				},
				"target": {
					"type": "object",
					"additionalProperties": false,
					"required": ["dependencyGraphDigest", "bindingDigests", "recordDigests"],
					"properties": {
						"dependencyGraphDigest": {
							"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
						},
						"bindingDigests": {
							"type": "array",
							"items": { "$ref": "#/definitions/NamedDigest" },
							"minItems": 1,
							"maxItems": 64
						},
						"recordDigests": {
							"type": "array",
							"items": { "$ref": "#/definitions/NamedDigest" },
							"minItems": 1,
							"maxItems": 64
						}
					}
				}
			}
		},
		"LinearV1ConversionBundle": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"schema",
				"sourceGateInput",
				"sourceGateResult",
				"topology",
				"dependencyGraph",
				"bindings",
				"records",
				"qualifiedCommits",
				"conversion"
			],
			"properties": {
				"schema": { "const": "graphrefly.stack.linear-v1-conversion-bundle.v1" },
				"sourceGateInput": {
					"$ref": "urn:graphrefly-stack:schema:semantic-artifacts:v1#/definitions/GateInput"
				},
				"sourceGateResult": {
					"$ref": "urn:graphrefly-stack:schema:semantic-artifacts:v1#/definitions/GateResult"
				},
				"topology": {
					"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/GitTopologySlice"
				},
				"dependencyGraph": {
					"$ref": "urn:graphrefly-stack:schema:dag-semantic-artifacts:v2#/definitions/SemanticDependencyGraph"
				},
				"bindings": {
					"type": "array",
					"items": {
						"$ref": "urn:graphrefly-stack:schema:dag-semantic-artifacts:v2#/definitions/WorkUnitBinding"
					},
					"minItems": 1,
					"maxItems": 64
				},
				"records": {
					"type": "array",
					"items": {
						"$ref": "urn:graphrefly-stack:schema:dag-semantic-artifacts:v2#/definitions/SemanticChangeRecord"
					},
					"minItems": 1,
					"maxItems": 64
				},
				"qualifiedCommits": {
					"type": "array",
					"items": { "$ref": "#/definitions/PlanQualifiedCommit" },
					"minItems": 1,
					"maxItems": 64
				},
				"conversion": { "$ref": "#/definitions/LinearV1Conversion" }
			}
		},
		"PlanIntegrationEvidence": {
			"type": "object",
			"additionalProperties": false,
			"required": ["planId", "planDigest", "policyDigest", "gateResultDigest", "verdict"],
			"properties": {
				"planId": {
					"$ref": "urn:graphrefly-stack:schema:semantic-artifacts:v1#/definitions/Identifier"
				},
				"planDigest": { "$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash" },
				"policyDigest": {
					"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
				},
				"gateResultDigest": {
					"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
				},
				"verdict": { "enum": ["pass", "blocked", "error"] }
			}
		},
		"QualifiedCommitDigest": {
			"type": "object",
			"additionalProperties": false,
			"required": ["planId", "workUnitId", "digest"],
			"properties": {
				"planId": {
					"$ref": "urn:graphrefly-stack:schema:semantic-artifacts:v1#/definitions/Identifier"
				},
				"workUnitId": {
					"$ref": "urn:graphrefly-stack:schema:semantic-artifacts:v1#/definitions/WorkUnitId"
				},
				"digest": { "$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash" }
			}
		},
		"QualifiedIntegrationConflict": {
			"type": "object",
			"additionalProperties": false,
			"required": ["planId", "workUnitId", "join", "conflict"],
			"properties": {
				"planId": {
					"oneOf": [
						{
							"$ref": "urn:graphrefly-stack:schema:semantic-artifacts:v1#/definitions/Identifier"
						},
						{ "type": "null" }
					]
				},
				"workUnitId": {
					"oneOf": [
						{
							"$ref": "urn:graphrefly-stack:schema:semantic-artifacts:v1#/definitions/WorkUnitId"
						},
						{ "type": "null" }
					]
				},
				"join": {
					"oneOf": [
						{ "$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/GitOid" },
						{ "type": "null" }
					]
				},
				"conflict": {
					"$ref": "urn:graphrefly-stack:schema:integration-artifacts:v1#/definitions/Conflict"
				}
			}
		},
		"JoinEffectEvidence": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"oid",
				"layer",
				"joinDigest",
				"targetDeltaDigest",
				"headDeltaDigest",
				"candidateDeltaDigest",
				"overlaps",
				"conflicts"
			],
			"properties": {
				"oid": { "$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/GitOid" },
				"layer": { "type": "integer", "minimum": 1, "maximum": 64 },
				"joinDigest": { "$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash" },
				"targetDeltaDigest": {
					"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
				},
				"headDeltaDigest": {
					"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
				},
				"candidateDeltaDigest": {
					"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
				},
				"overlaps": {
					"type": "array",
					"items": {
						"$ref": "urn:graphrefly-stack:schema:integration-artifacts:v1#/definitions/OverlapWitness"
					},
					"maxItems": 256,
					"uniqueItems": true
				},
				"conflicts": {
					"type": "array",
					"items": {
						"$ref": "urn:graphrefly-stack:schema:integration-artifacts:v1#/definitions/Conflict"
					},
					"maxItems": 256,
					"uniqueItems": true
				}
			}
		},
		"GroupIntegrationInput": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"schema",
				"topologyDigest",
				"headBlueprintDigest",
				"repositoryPolicyDigest",
				"qualifiedCommitDigests",
				"plans",
				"joins",
				"semanticConflicts"
			],
			"properties": {
				"schema": { "const": "graphrefly.stack.group-integration-input.v1" },
				"topologyDigest": {
					"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
				},
				"headBlueprintDigest": {
					"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
				},
				"repositoryPolicyDigest": {
					"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
				},
				"qualifiedCommitDigests": {
					"type": "array",
					"items": { "$ref": "#/definitions/QualifiedCommitDigest" },
					"minItems": 1,
					"maxItems": 64
				},
				"plans": {
					"type": "array",
					"items": { "$ref": "#/definitions/PlanIntegrationEvidence" },
					"minItems": 1,
					"maxItems": 8
				},
				"joins": {
					"type": "array",
					"items": { "$ref": "#/definitions/JoinEffectEvidence" },
					"maxItems": 63
				},
				"semanticConflicts": {
					"type": "array",
					"items": { "$ref": "#/definitions/QualifiedIntegrationConflict" },
					"maxItems": 512,
					"uniqueItems": true
				}
			}
		},
		"GroupJoinEvaluation": {
			"type": "object",
			"additionalProperties": false,
			"required": ["oid", "joinDigest", "valid", "reasonCodes", "overlaps", "conflicts"],
			"properties": {
				"oid": { "$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/GitOid" },
				"joinDigest": { "$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash" },
				"valid": { "type": "boolean" },
				"reasonCodes": {
					"type": "array",
					"items": {
						"$ref": "urn:graphrefly-stack:schema:integration-artifacts:v1#/definitions/ReasonCode"
					},
					"uniqueItems": true
				},
				"overlaps": {
					"type": "array",
					"items": {
						"$ref": "urn:graphrefly-stack:schema:integration-artifacts:v1#/definitions/OverlapWitness"
					},
					"maxItems": 256,
					"uniqueItems": true
				},
				"conflicts": {
					"type": "array",
					"items": {
						"$ref": "urn:graphrefly-stack:schema:integration-artifacts:v1#/definitions/Conflict"
					},
					"maxItems": 256,
					"uniqueItems": true
				}
			}
		},
		"GroupIntegrationResult": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"schema",
				"inputDigest",
				"verdict",
				"reasonCodes",
				"plans",
				"joins",
				"conflicts"
			],
			"properties": {
				"schema": { "const": "graphrefly.stack.group-integration-result.v1" },
				"inputDigest": {
					"$ref": "urn:graphrefly-stack:schema:dag-artifacts:v2#/definitions/Hash"
				},
				"verdict": { "enum": ["pass", "blocked", "error"] },
				"reasonCodes": {
					"type": "array",
					"items": {
						"$ref": "urn:graphrefly-stack:schema:integration-artifacts:v1#/definitions/ReasonCode"
					},
					"uniqueItems": true
				},
				"plans": {
					"type": "array",
					"items": { "$ref": "#/definitions/PlanIntegrationEvidence" },
					"minItems": 1,
					"maxItems": 8
				},
				"joins": {
					"type": "array",
					"items": { "$ref": "#/definitions/GroupJoinEvaluation" },
					"maxItems": 63
				},
				"conflicts": {
					"type": "array",
					"items": { "$ref": "#/definitions/QualifiedIntegrationConflict" },
					"maxItems": 512,
					"uniqueItems": true
				}
			}
		}
	}
}
