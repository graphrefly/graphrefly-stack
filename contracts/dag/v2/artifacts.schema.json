{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "urn:graphrefly-stack:schema:dag-artifacts:v2",
	"title": "GraphReFly Stack bounded DAG artifacts v2",
	"definitions": {
		"Hash": {
			"type": "object",
			"additionalProperties": false,
			"required": ["algorithm", "value"],
			"properties": {
				"algorithm": { "const": "sha256" },
				"value": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
			}
		},
		"GitOid": {
			"oneOf": [
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["algorithm", "value"],
					"properties": {
						"algorithm": { "const": "sha1" },
						"value": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
					}
				},
				{
					"type": "object",
					"additionalProperties": false,
					"required": ["algorithm", "value"],
					"properties": {
						"algorithm": { "const": "sha256" },
						"value": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
					}
				}
			]
		},
		"Identifier": {
			"type": "string",
			"pattern": "^[A-Za-z][A-Za-z0-9._-]{0,63}$"
		},
		"RepositoryIdentity": {
			"type": "object",
			"additionalProperties": false,
			"required": ["provider", "owner", "name"],
			"properties": {
				"provider": { "type": "string", "pattern": "^[a-z][a-z0-9-]{0,31}$" },
				"owner": { "type": "string", "minLength": 1, "maxLength": 128 },
				"name": { "type": "string", "minLength": 1, "maxLength": 128 }
			}
		},
		"ProviderIdentity": {
			"type": "object",
			"additionalProperties": false,
			"required": ["kind", "runtimeVersion", "blueprintVersion"],
			"properties": {
				"kind": { "const": "graphrefly" },
				"runtimeVersion": {
					"type": "string",
					"pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
				},
				"blueprintVersion": { "const": "v2" }
			}
		},
		"Limits": {
			"type": "object",
			"additionalProperties": false,
			"required": ["maxObjects", "maxWidth", "maxParents"],
			"properties": {
				"maxObjects": { "const": 64 },
				"maxWidth": { "const": 8 },
				"maxParents": { "const": 2 }
			}
		},
		"TopologyObject": {
			"type": "object",
			"additionalProperties": false,
			"required": ["oid", "parents", "layer", "kind", "workUnitId", "blueprintHash"],
			"oneOf": [
				{
					"properties": {
						"kind": { "const": "implementation" },
						"parents": { "type": "array", "minItems": 1, "maxItems": 1 },
						"workUnitId": { "$ref": "#/definitions/Identifier" }
					}
				},
				{
					"properties": {
						"kind": { "const": "join" },
						"parents": { "type": "array", "minItems": 2, "maxItems": 2 },
						"workUnitId": { "type": "null" }
					}
				}
			],
			"properties": {
				"oid": { "$ref": "#/definitions/GitOid" },
				"parents": {
					"type": "array",
					"items": { "$ref": "#/definitions/GitOid" },
					"minItems": 1,
					"maxItems": 2,
					"uniqueItems": true
				},
				"layer": { "type": "integer", "minimum": 1, "maximum": 64 },
				"kind": { "enum": ["implementation", "join"] },
				"workUnitId": {
					"oneOf": [{ "$ref": "#/definitions/Identifier" }, { "type": "null" }]
				},
				"blueprintHash": { "$ref": "#/definitions/Hash" }
			}
		},
		"DeltaEvidence": {
			"type": "object",
			"additionalProperties": false,
			"required": ["from", "to", "deltaDigest"],
			"properties": {
				"from": { "$ref": "#/definitions/GitOid" },
				"to": { "$ref": "#/definitions/GitOid" },
				"deltaDigest": { "$ref": "#/definitions/Hash" }
			}
		},
		"JoinBinding": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"schema",
				"oid",
				"parents",
				"layer",
				"mergeBase",
				"merge",
				"parentDeltas",
				"joinBlueprintHash"
			],
			"properties": {
				"schema": { "const": "graphrefly.stack.join-binding.v2" },
				"oid": { "$ref": "#/definitions/GitOid" },
				"parents": {
					"type": "array",
					"items": { "$ref": "#/definitions/GitOid" },
					"minItems": 2,
					"maxItems": 2,
					"uniqueItems": true
				},
				"layer": { "type": "integer", "minimum": 1, "maximum": 64 },
				"mergeBase": { "$ref": "#/definitions/GitOid" },
				"merge": {
					"type": "object",
					"additionalProperties": false,
					"required": ["algorithm", "revision", "candidateTree", "observedTree"],
					"properties": {
						"algorithm": { "const": "git-ort-three-way" },
						"revision": { "const": "v1" },
						"candidateTree": { "$ref": "#/definitions/GitOid" },
						"observedTree": { "$ref": "#/definitions/GitOid" }
					}
				},
				"parentDeltas": {
					"type": "array",
					"items": { "$ref": "#/definitions/DeltaEvidence" },
					"minItems": 2,
					"maxItems": 2
				},
				"joinBlueprintHash": { "$ref": "#/definitions/Hash" }
			}
		},
		"GitTopologySlice": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"schema",
				"repository",
				"provider",
				"base",
				"head",
				"baseBlueprintHash",
				"limits",
				"objects",
				"joins"
			],
			"properties": {
				"schema": { "const": "graphrefly.stack.git-topology-slice.v2" },
				"repository": { "$ref": "#/definitions/RepositoryIdentity" },
				"provider": { "$ref": "#/definitions/ProviderIdentity" },
				"base": { "$ref": "#/definitions/GitOid" },
				"head": { "$ref": "#/definitions/GitOid" },
				"baseBlueprintHash": { "$ref": "#/definitions/Hash" },
				"limits": { "$ref": "#/definitions/Limits" },
				"objects": {
					"type": "array",
					"items": { "$ref": "#/definitions/TopologyObject" },
					"minItems": 1,
					"maxItems": 64
				},
				"joins": {
					"type": "array",
					"items": { "$ref": "#/definitions/JoinBinding" },
					"maxItems": 63
				}
			}
		}
	}
}
