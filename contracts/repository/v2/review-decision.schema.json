{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "urn:graphrefly-stack:schema:repository-review-decision:v2",
	"title": "GraphReFly Stack whole-change review decision v2",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"schema",
		"id",
		"target",
		"decision",
		"reviewerLabel",
		"summary",
		"recordedAt",
		"identityVerified"
	],
	"properties": {
		"schema": { "const": "graphrefly.stack.repository-review-decision.v2" },
		"id": {
			"type": "string",
			"pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
		},
		"target": {
			"type": "object",
			"additionalProperties": false,
			"required": ["baseOid", "headOid", "reviewTargetDigest"],
			"properties": {
				"baseOid": {
					"$ref": "urn:graphrefly-stack:schema:repository-review:v1#/definitions/GitOid"
				},
				"headOid": {
					"$ref": "urn:graphrefly-stack:schema:repository-review:v1#/definitions/GitOid"
				},
				"reviewTargetDigest": {
					"type": "object",
					"additionalProperties": false,
					"required": ["algorithm", "value"],
					"properties": {
						"algorithm": { "const": "sha256" },
						"value": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
					}
				}
			}
		},
		"contextCommitOid": {
			"$ref": "urn:graphrefly-stack:schema:repository-review:v1#/definitions/GitOid"
		},
		"decision": { "enum": ["approve", "request-changes"] },
		"reviewerLabel": { "type": "string", "minLength": 1, "maxLength": 120 },
		"summary": { "type": "string", "maxLength": 10000 },
		"recordedAt": {
			"type": "string",
			"pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
		},
		"identityVerified": { "const": false }
	}
}
